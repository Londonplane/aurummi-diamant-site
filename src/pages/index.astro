---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';

const articles = (await getCollection('ratgeber', ({ data }) => !data.noindex))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const canonicalURL = new URL('/', Astro.site).toString();
---

<Layout
  title="Labordiamanten: Nachhaltige Diamanten kaufen"
  description="Aurummi ist Ihr Ratgeber für IGI-zertifizierte Labordiamanten in Deutschland: echte Diamanten, transparent erklärt und nachhaltig gedacht."
  canonicalURL={canonicalURL}
  schema="article"
  breadcrumbs={[{ name: 'Startseite', item: canonicalURL }]}
>
  <section class="border-b border-gray-200 bg-gray-50">
    <div class="mx-auto grid max-w-6xl gap-10 px-4 py-16 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div class="min-w-0">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold-600">Aurummi</p>
        <h1 class="mt-4 max-w-3xl break-words text-3xl font-bold leading-tight text-gray-950 sm:text-5xl">
          Echte Diamanten. Nachhaltig hergestellt.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-gray-600">
          Aurummi erklärt Labordiamanten für Käuferinnen, Käufer und Händler in Deutschland:
          IGI-Zertifikate, Preise, Herkunft und Qualitätsmerkmale verständlich an einem Ort.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/labordiamanten/" class="bg-gray-950 px-5 py-3 font-medium text-white transition-colors hover:bg-gray-700">
            Zum Ratgeber
          </a>
          <a href="/labordiamanten-grosshandel/" class="border border-gray-300 px-5 py-3 font-medium text-gray-950 transition-colors hover:border-gray-950">
            Großhandel anfragen
          </a>
        </div>
      </div>
      <div class="min-w-0 border border-gray-200 bg-white p-8">
        <div class="aspect-square border border-gold-500 p-8">
          <div class="flex h-full flex-col justify-between">
            <span class="text-sm uppercase tracking-[0.25em] text-gray-500">Lab-grown</span>
            <div>
              <p class="text-6xl font-semibold text-gray-950">IGI</p>
              <p class="mt-3 max-w-xs text-sm leading-6 text-gray-600">
                Zertifizierte CVD- und HPHT-Labordiamanten mit transparenter Qualitätsbewertung.
              </p>
            </div>
            <span class="text-sm text-gold-600">CVD / HPHT / 4C</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {articles.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
      <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
        <div>
          <p class="text-sm font-medium uppercase tracking-[0.18em] text-gold-600">Ratgeber</p>
          <h2 class="mt-2 text-2xl font-semibold text-gray-950">Aktuelle Artikel</h2>
        </div>
        <a href="/labordiamanten/" class="text-sm font-medium text-gray-700 hover:text-gold-600">Alle Artikel</a>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {articles.map((entry) => (
          <a href={`/labordiamanten/${entry.id}/`} class="block border border-gray-200 p-5 transition-colors hover:border-gold-500">
            <p class="text-sm font-semibold text-gray-950">{entry.data.title}</p>
            <p class="mt-3 text-sm leading-6 text-gray-600">{entry.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="mx-auto max-w-6xl px-4 sm:px-6">
    <NewsletterCTA />
  </section>

  <p class="px-4 pb-12 text-center text-sm text-gray-500">
    Demnächst: IGI-zertifizierte Labordiamanten für Ring- und Schmuckprojekte.
  </p>
</Layout>
