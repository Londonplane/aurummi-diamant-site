---
import Layout from '../layouts/Layout.astro';

const canonicalURL = new URL('/impressum/', Astro.site).toString();
---

<Layout
  title="Impressum: Aurummi"
  description="Impressum von Aurummi gemäß § 5 TMG."
  canonicalURL={canonicalURL}
  schema="article"
  breadcrumbs={[
    { name: 'Startseite', item: new URL('/', Astro.site).toString() },
    { name: 'Impressum', item: canonicalURL },
  ]}
>
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <h1 class="break-words text-3xl font-bold leading-tight text-gray-950 sm:text-4xl">Impressum</h1>
    <div class="mt-8 border border-gray-200 p-6 text-gray-600">
      <p class="italic">[Angaben gemäß § 5 TMG hier einfügen: Name, Anschrift, Kontakt, Umsatzsteuer-ID]</p>
    </div>
  </article>
</Layout>
