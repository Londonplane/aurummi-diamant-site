---
import Layout from '../layouts/Layout.astro';

const canonicalURL = new URL('/datenschutz/', Astro.site).toString();
---

<Layout
  title="Datenschutzerklärung: Aurummi"
  description="Datenschutzerklärung von Aurummi gemäß DSGVO."
  canonicalURL={canonicalURL}
  schema="article"
  breadcrumbs={[
    { name: 'Startseite', item: new URL('/', Astro.site).toString() },
    { name: 'Datenschutz', item: canonicalURL },
  ]}
>
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <h1 class="break-words text-3xl font-bold leading-tight text-gray-950 sm:text-4xl">Datenschutzerklärung</h1>
    <div class="mt-8 border border-gray-200 p-6 text-gray-600">
      <p class="italic">[Datenschutzerklärung gemäß DSGVO hier einfügen]</p>
    </div>
  </article>
</Layout>
