<section id="newsletter" class="my-16 bg-gray-950 px-6 py-10 text-center text-white sm:px-10">
  <h2 class="text-2xl font-semibold">Bleiben Sie informiert</h2>
  <p class="mx-auto mt-3 max-w-2xl text-gray-300">
    Aktuelle Ratgeber, Markteinblicke und Hinweise zu IGI-zertifizierten Labordiamanten direkt in Ihr Postfach.
  </p>
  <form action="#" method="post" class="mx-auto mt-7 grid max-w-md gap-3 sm:grid-cols-[1fr_auto]">
    <label class="sr-only" for="newsletter-email">E-Mail-Adresse</label>
    <input
      id="newsletter-email"
      type="email"
      name="email"
      required
      placeholder="ihre@email.de"
      class="min-w-0 border border-gray-300 bg-white px-4 py-3 text-gray-900 outline-none focus:border-gold-500"
    />
    <button type="submit" class="bg-gold-500 px-5 py-3 font-semibold text-gray-950 transition-colors hover:bg-amber-300">
      Anmelden
    </button>
  </form>
</section>
