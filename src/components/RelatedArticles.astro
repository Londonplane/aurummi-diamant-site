---
import { getCollection } from 'astro:content';

interface Props {
  slugs: string[];
}

const { slugs } = Astro.props;
const articles = await getCollection('ratgeber', ({ data }) => !data.noindex);
const related = slugs
  .map((slug) => articles.find((entry) => entry.id === slug))
  .filter((entry): entry is (typeof articles)[number] => entry !== undefined);
---

{related.length > 0 && (
  <section class="mt-12">
    <h2 class="mb-4 text-xl font-semibold text-gray-950">Weitere Ratgeber</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {related.map((entry) => (
        <a href={`/labordiamanten/${entry.id}/`} class="block border border-gray-200 p-4 transition-colors hover:border-gold-500">
          <p class="font-medium text-gray-950">{entry.data.title}</p>
          <p class="mt-2 text-sm leading-6 text-gray-600">{entry.data.description}</p>
        </a>
      ))}
    </div>
  </section>
)}
