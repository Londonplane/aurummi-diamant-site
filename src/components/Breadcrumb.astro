---
interface Item {
  name: string;
  href: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-8 min-w-0 text-sm text-gray-500">
  <ol class="flex min-w-0 flex-wrap items-center gap-1">
    {items.map((item, index) => (
      <li class="flex min-w-0 items-center gap-1">
        {index < items.length - 1 ? (
          <a href={item.href} class="hover:text-gray-900">{item.name}</a>
        ) : (
          <span class="min-w-0 break-words text-gray-900" aria-current="page">{item.name}</span>
        )}
        {index < items.length - 1 && <span aria-hidden="true">/</span>}
      </li>
    ))}
  </ol>
</nav>
